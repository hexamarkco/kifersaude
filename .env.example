# Preencha estes valores com a URL e chaves do seu projeto Supabase.
# Exemplos:
# - Projeto hospedado: https://<project>.supabase.co
# - Supabase CLI (local): http://127.0.0.1:54321

VITE_SUPABASE_URL=https://<project>.supabase.co
# Opcionalmente, utilize o endpoint local da CLI: http://127.0.0.1:54321/functions/v1
VITE_SUPABASE_FUNCTIONS_URL=https://<project>.supabase.co/functions/v1
VITE_SUPABASE_ANON_KEY=seu-anon-key

# IMPORTANTE:
# Nunca exponha a service role key com prefixo VITE_.
# Use apenas em ambiente servidor/secrets como:
# SUPABASE_SERVICE_ROLE_KEY=seu-service-role-key
